{
  "title": "YDB .NET SDK — HTTP/gRPC Transport",
  "uid": "ydb-sdk-http",
  "panels": [
    {
      "title": "HTTP Request Rate (RPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum(rate(http_client_request_duration_seconds_count[$__rate_interval]))",
          "legendFormat": "Requests/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "HTTP Error Rate by Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum by (http_response_status_code, error_type) (rate(http_client_request_duration_seconds_count{http_response_status_code!=\"200\"}[$__rate_interval]))",
          "legendFormat": "{{http_response_status_code}} {{error_type}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "Active HTTP Requests",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(http_client_active_requests)",
          "legendFormat": "Active",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "HTTP/2 Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum(http_client_open_connections{http_connection_state=\"active\"})",
          "legendFormat": "Active",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(http_client_open_connections{http_connection_state=\"idle\"})",
          "legendFormat": "Idle",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "HTTP Request Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_client_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_client_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_client_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "HTTP Request Time in Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_client_request_time_in_queue_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_client_request_time_in_queue_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_client_request_time_in_queue_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "title": "HTTP/2 Connection Lifetime",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_client_connection_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_client_connection_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_client_connection_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "timezone": "browser"
}
